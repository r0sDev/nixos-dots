// Made by MHIA
// Github: https://github.com/MHashir09
// Note: Do not tinker with the spaces I have put here,
// else the UI may break

{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
      "type": "small",
 //     "source": "~/.config/fastfetch/logo/frieren.txt",
      "source": "nixos",
      "height": 12,
      "padding": {
        "top": 2,
        "right": 5,
        "left": 3
      }
    },
    "display": {
        "separator": "  ",
        "color": "white"
    },
    "modules": [
        "break",
        {
            "type": "custom",
            "key": "╭─────────────────────────────────────────╮"
        },
        {
            "type": "custom",
            "key": "│                                         │"
        },
         {
            "type": "os",
            "key": "│  OS           ",
            "format": "{pretty-name>22}  │"
        },
        {
            "type": "command",
            "key": "│  Kernel       ",
            "text": "uname -r | cut -d '-' -f1",
            "format": "{>22}  │"
        },
        {
            "type": "command",
            "key": "│  Uptime       ",
            "text": "uptime -p | sed -E 's/up //; s/ days?/d/g; s/ hours?/h/g; s/ minutes?/m/g'",
            "format": "{>22}  │"
        },
        {
            "type": "shell",
            "key": "│  Shell        ",
            "format": "{pretty-name>22}  │"
        },
        {
            "type": "command",
            "key": "│  WM           ",
            "text": "echo $XDG_CURRENT_DESKTOP",
            "format": "{>22}  │"
        },
        {
	        "key": "│  OS Age                      ",
            "type": "disk",
	        "folders": "/",
	        "format": "{days} days │"
	    },
        {
            "type": "command",
            "key": "│  Ram          ",
            "text": "free -m | awk 'NR==2{printf \"%.2f / %.2f GiB\",$3/1024,$2/1024}'",
            "format": "{>22}  │"
        },
        {
            "type": "command",
            "key": "│  Disk         ",
            "text": "df -h --output=size,used,fstype / | awk 'NR==2 {gsub(/G/,\"\",$1); gsub(/G/,\"\",$2); print $2 \" / \" $1 \" GiB - \" $3}'",
            "format": "{>22}  │"
        },
        {
            "type": "packages",
            "key": "│  Packages     ",
            "format": "{all>22}  │"
        },
        {
            "type": "command",
            "key": "│  Owner        ",
            "text": "echo $USER | tr '[:lower:]' '[:upper:]'",
            "format": "{>22}  │"
        },
        {
            "type": "custom",
            "key": "│                                         │"
        },
        {
            "type": "command",
            "key": " ",
            "shell": "/bin/bash",
            "text": "echo '│     WE ARE LIBRE ! ── 我々は自由だ！    │'",
            "format": "{1}"
        },
        {
            "type": "custom",
            "key": "╰─────────────────────────────────────────╯"
        },
        "break"
    ]
}
