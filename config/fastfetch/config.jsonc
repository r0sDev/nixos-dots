{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "nixos_small",
    "type": "small",
    "width": 3,
    "height": 3,
    "padding": {
      "top": 1,
      "right": 0,
      "left": 1,
    },
    "color": {    
    "1":"white"
    }
  },

  "display": {
    "separator": " ",
    "color": {
      "keys": "white",
    },
  },

  "modules": [
    {
      "type": "break",
    },
    {
      "key": " term   ",
      "type": "terminal",
    },
    {
      "key": " shell  ",
      "type": "shell",
    },
    {
      "key": " kernel ",
      "type": "kernel",
    },
    {
      "type": "packages",
      "key": " pkgs   ",
    },
    {
      "key": " uptime ",
      "type": "uptime",
    },
    {
      "type": "command",
      "key": " os age ",
      "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days",
    },
  ],
}
